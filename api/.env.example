PORT=5000
MONGODB_URI=mongodb://localhost:27017/owomi
JWT_SECRET=your-super-secret-jwt-key-change-this
NODE_ENV=development
PAYMENT_PROVIDER=mock

# Payment Gateway (Paystack/Flutterwave)
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# Virtual Account Provider (Wema/Providus)
WEMA_API_KEY=your-wema-api-key

# Monnify (real bank transfers + reserved accounts)
MONNIFY_BASE_URL=https://api.monnify.com/api/v1
MONNIFY_API_KEY=your-monnify-api-key
MONNIFY_SECRET_KEY=your-monnify-secret-key
MONNIFY_CONTRACT_CODE=your-monnify-contract-code
MONNIFY_SOURCE_ACCOUNT_NUMBER=your-monnify-source-account-number
